# ─────────────────────────────────────────────────────────────
# EcoPremium — переменные окружения для Netlify-функции заказа
# Скопируйте в .env для локальной разработки (netlify dev)
# и пропишите эти же ключи в Netlify → Site settings → Environment variables.
# В коде НИКАКИЕ секреты не хранятся. Все значения вводит клиент / вы с его разрешения.
# Любая интеграция необязательна: если ключи не заданы — этот канал просто пропускается,
# заявка всё равно уходит в остальные каналы и пользователь видит успех.
# ─────────────────────────────────────────────────────────────

# ── amoCRM ──
# Поддомен аккаунта без https:// (например: ekopremium)
AMOCRM_SUBDOMAIN=
# Долгоживущий токен доступа (Long-lived token) из приватной интеграции amoCRM
AMOCRM_ACCESS_TOKEN=
# ID воронки и статуса, куда класть новые заявки (необязательно — без них сделка падёт в дефолтную воронку)
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=
# ID кастомных полей контакта (field_id) для телефона и email. Узнать через GET /api/v4/contacts/custom_fields
AMOCRM_PHONE_FIELD_ID=
AMOCRM_EMAIL_FIELD_ID=

# ── Telegram ──
# Токен бота @Ecopremi_bot от @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID, куда слать заявки (узнать через @userinfobot или getUpdates). Можно несколько через запятую.
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ──
# SMTP клиента. Для mail.ru: host smtp.mail.ru, port 465, secure=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# От кого и кому отправлять дубль заявки
ORDER_EMAIL_FROM=
ORDER_EMAIL_TO=maslo8540@mail.ru
