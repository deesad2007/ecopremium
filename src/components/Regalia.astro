---
// Секция «Наши сертификаты и регалии» — знаки отличия.
const items = [
  { t: 'Поставщик Московского Кремля', d: 'Поставляем продукцию структурам Управления делами Президента РФ', icon: 'kremlin' },
  { t: 'Органический ГОСТ 33980-2016', d: 'Единственные в России с органическим сертификатом этого стандарта', icon: 'leaf' },
  { t: '№065 «Роскачество»', d: 'Сертификат соответствия системы добровольной сертификации', icon: 'star' },
  { t: 'Госреестр Минсельхоза РФ', d: 'Внесены в государственный реестр Министерства сельского хозяйства', icon: 'doc' },
  { t: 'Лаборатория УД Президента РФ', d: 'Контроль качества в лаборатории Управделами Президента', icon: 'flask' },
];
const icons = {
  kremlin: '<path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-7h6v7"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  star: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/>',
  flask: '<path d="M9 2h6M10 2v6.5L5 18a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 18l-5-9.5V2"/><path d="M7.5 14h9"/>',
};
---
<section class="regalia" id="regalia">
  <div class="section-inner">
    <div class="head">
      <div class="lbl ey">Знаки отличия</div>
      <h2>Наши сертификаты <em>и регалии</em></h2>
      <div class="rule"></div>
    </div>
    <div class="regalia-grid">
      {items.map((it) => (
        <div class="regalia-card">
          <div class="medal"><svg viewBox="0 0 24 24" set:html={icons[it.icon]}></svg></div>
          <h4>{it.t}</h4>
          <p>{it.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>
