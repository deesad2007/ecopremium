---
import Base from '../layouts/Base.astro';
import Credentials from '../components/Credentials.astro';
import Regalia from '../components/Regalia.astro';
import ProductCard from '../components/ProductCard.astro';
import data from '../data/products.json';

const products = data.products;
const usp = [
  { t: 'Поставщик Московского Кремля', d: 'Контроль качества в лаборатории Управделами Президента РФ.' },
  { t: 'Единственный органик ГОСТ в России', d: 'Органический сертификат ГОСТ 33980-2016, №065 «Роскачество», Госреестр Минсельхоза.' },
  { t: 'Ручной отжим на дереве', d: 'Деревянный пресс при комнатной температуре, без нагрева и контакта с металлом.' },
  { t: 'Свежее под заказ', d: 'Не давим впрок — отжим в день отправки. Сегодня формируем заказы на завтра.' },
];
---
<Base>
  {/* ── HERO ── */}
  <div class="hero">
    <div class="hero-grain"></div>
    <div class="hero-inner">
      <div>
        <div class="kremlin-line">
          <svg viewBox="0 0 24 24"><path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-7h6v7"/></svg>
          Поставщик Московского Кремля
        </div>
        <h1>Сыродавленные масла, <em>как сотни лет назад</em></h1>
        <div class="rule"></div>
        <p class="lead">Давим вручную на деревянном прессе при комнатной температуре — без нагрева и контакта с металлом. Так сохраняется природный вкус, аромат и состав сырья.</p>
        <div class="acts">
          <a href="/catalog" class="btn btn-g">Выбрать масло</a>
          <a href="/about" class="btn btn-o">Наша технология</a>
        </div>
        <div class="hero-badges">
          <span>Органик ГОСТ 33980-2016</span>
          <span>№065 Роскачество</span>
          <span>Лаборатория УД Президента РФ</span>
        </div>
      </div>
      <div class="art">
        <div class="art-photo">
          <img src="/img/hero.jpg" alt="Сыродавленное органическое масло EcoPremi" loading="eager" fetchpriority="high" />
        </div>
        <div class="frame2"></div><div class="frame"></div>
        <div class="seal"><div class="lbl">Поставщик</div><b>Кремля</b><div class="lbl">органик ГОСТ</div></div>
      </div>
    </div>
  </div>

  {/* ── TRUST STRIP ── */}
  <Credentials />

  {/* ── TOP PRODUCTS ── */}
  <section id="catalog">
    <div class="section-inner">
      <div class="head">
        <div class="lbl ey">Каталог</div>
        <h2>Масла, отжатые <em>сегодня для вас</em></h2>
        <div class="rule"></div>
      </div>
      <div class="grid">
        {products.map((p) => <ProductCard product={p} />)}
      </div>
      <div style="text-align:center;margin-top:48px">
        <a href="/catalog" class="btn btn-dark">Весь каталог</a>
      </div>
    </div>
  </section>

  {/* ── TECHNOLOGY ── */}
  <section class="craft" id="craft">
    <div class="section-inner">
      <div class="head light">
        <div class="lbl ey" style="color:var(--gold)">Технология</div>
        <h2>Почему <em>сыродавленное</em></h2>
        <div class="rule"></div>
      </div>
      <div class="vs">
        <div class="vbox bad">
          <div class="tag">Холодный отжим</div>
          <p>Семена прогоняют через металлический шнековый пресс, где они нагреваются. Часть полезных веществ теряется, масло окисляется при контакте с металлом, нередко добавляют консерванты.</p>
        </div>
        <div class="vbox good">
          <div class="tag">Сыродавленное</div>
          <p>Давим старинным способом на ручном прессе при комнатной температуре, без соприкосновения с металлом. Биологически активные вещества сырья сохраняются.</p>
        </div>
      </div>
      <div class="note">Приезжайте на маслодельню и увидите весь процесс своими глазами — нам нечего скрывать.</div>
    </div>
  </section>

  {/* ── USP LIST ── */}
  <section>
    <div class="section-inner">
      <div class="head">
        <div class="lbl ey">Почему мы</div>
        <h2>Чем мы <em>отличаемся</em></h2>
        <div class="rule"></div>
      </div>
      <ul class="usp">
        {usp.map((u) => (
          <li>
            <span class="ic"><svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg></span>
            <div><b>{u.t}</b><p>{u.d}</p></div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ── REGALIA ── */}
  <Regalia />

  {/* ── CLOSING CTA ── */}
  <section class="closing">
    <div class="section-inner">
      <h2>Закажите масло, <em>отжатое именно для вас</em></h2>
      <p>Формируем заказы сегодня — на завтра. Бесплатная доставка от 10&nbsp;000&nbsp;₽ по всей России.</p>
      <button class="btn btn-g" data-order>Оформить заявку</button>
    </div>
  </section>
</Base>
