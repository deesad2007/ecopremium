---
import Base from '../layouts/Base.astro';
import { contacts } from '../data/site.js';
---
<Base title="Контакты — EcoPremi" description="Связаться с EcoPremi: телефон, WhatsApp, Telegram, e-mail, ВКонтакте.">
  <section class="page-hero">
    <div class="ey lbl">Контакты</div>
    <h1>Свяжитесь <em>с нами</em></h1>
    <p>Работаем без выходных. Ответим в мессенджерах быстро, по доставке пишите в наш Telegram-бот.</p>
  </section>

  <section>
    <div class="section-inner">
      <div class="contact-grid">
        <a class="contact-card" href={`tel:${contacts.phoneRaw}`}>
          <div class="ic"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <h4>Телефон</h4><p>{contacts.phone}</p>
        </a>
        <a class="contact-card" href={contacts.whatsapp} target="_blank" rel="noopener">
          <div class="ic"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg></div>
          <h4>WhatsApp</h4><p>Написать в WhatsApp</p>
        </a>
        <a class="contact-card" href={contacts.telegram} target="_blank" rel="noopener">
          <div class="ic"><svg viewBox="0 0 24 24"><path d="M21.5 4.5l-19 8 6 2 2 6 3-4 5 4 3-16z"/></svg></div>
          <h4>Telegram</h4><p>Канал и бот {contacts.telegramBot}</p>
        </a>
        <a class="contact-card" href={`mailto:${contacts.email}`}>
          <div class="ic"><svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg></div>
          <h4>E-mail</h4><p>{contacts.email}</p>
        </a>
        <a class="contact-card" href={contacts.vk} target="_blank" rel="noopener">
          <div class="ic"><svg viewBox="0 0 24 24"><path d="M4 5h16v14H4z" fill="none"/><path d="M6 9c.5 4 3 6.5 6 6.5h1V13c1.5 0 3 1.5 3.5 2.5H19c-.5-1.5-2-3-3-3.5 1-.7 2.3-2.3 2.5-3.5H17c-.4 1-1.5 2.3-3 2.8V9h-1.5v3C11 11.5 9.5 10 9 9z"/></svg></div>
          <h4>ВКонтакте</h4><p>Сообщество EcoPremi</p>
        </a>
        <a class="contact-card" href="/catalog">
          <div class="ic"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18M16 10a4 4 0 0 1-8 0"/></svg></div>
          <h4>Каталог</h4><p>Выбрать и заказать масло</p>
        </a>
      </div>
      <div style="text-align:center;margin-top:48px">
        <button class="btn btn-g" data-order>Оставить заявку</button>
      </div>
    </div>
  </section>
</Base>
