---
import Base from '../layouts/Base.astro';
import Regalia from '../components/Regalia.astro';
import Credentials from '../components/Credentials.astro';

const faq = [
  { q: 'Чем настоящее живое масло отличается от магазинного?', a: 'Живое масло отжимается на ручном прессе при комнатной температуре, без нагрева и контакта с металлом — так сохраняется природный вкус, аромат и вещества сырья. Магазинное масло часто рафинируют и нагревают.' },
  { q: 'Как вы делаете живое масло?', a: 'Ручной деревянный пресс, комнатная температура, без соприкосновения с металлом. Отжим происходит в день заказа, чтобы масло было максимально свежим.' },
  { q: 'Сколько хранятся сыродавленные масла?', a: 'Это нерафинированный живой продукт с ограниченным сроком хранения. Храните в холодильнике в тёмной таре и употребляйте в течение срока, указанного на этикетке.' },
  { q: 'Не горчат ли масла?', a: 'У некоторых нерафинированных масел возможна лёгкая природная горчинка — это нормально для живого продукта.' },
  { q: 'Из какого сырья делаете масло?', a: 'Используем органическое сырьё, выращенное без ядохимикатов и удобрений, с органическим сертификатом.' },
  { q: 'Что такое жмых и мука?', a: 'Это остаток после отжима. Используется в пищу как источник клетчатки и добавка к блюдам.' },
  { q: 'Почему в масле бывают точки и кусочки?', a: 'Это естественный осадок нерафинированного масла, а не признак порчи.' },
];
---
<Base title="Технология и сертификаты — EcoPremi" description="Сыродавленное против холодного отжима. Органические сертификаты, регалии и ответы на частые вопросы EcoPremi.">
  <section class="page-hero">
    <div class="ey lbl">О нас</div>
    <h1>Масло, отжатое <em>как сотни лет назад</em></h1>
    <p>Ручной деревянный пресс, комнатная температура, органическое сырьё. Подаём дорого и честно — без медицинских обещаний.</p>
  </section>

  {/* технология vs */}
  <section class="craft">
    <div class="section-inner">
      <div class="head light">
        <div class="lbl ey" style="color:var(--gold)">Технология</div>
        <h2>Сыродавленное против <em>холодного отжима</em></h2>
        <div class="rule"></div>
      </div>
      <div class="vs">
        <div class="vbox bad">
          <div class="tag">Холодный отжим</div>
          <p>Семена прогоняют через металлический шнековый пресс, где они нагреваются от трения. Часть полезных веществ теряется, масло окисляется при контакте с металлом, нередко добавляют консерванты.</p>
        </div>
        <div class="vbox good">
          <div class="tag">Сыродавленное</div>
          <p>Давим старинным способом на ручном деревянном прессе при комнатной температуре, без соприкосновения с металлом. Биологически активные вещества сырья сохраняются.</p>
        </div>
      </div>
      <div class="note">Приезжайте на маслодельню и увидите весь процесс своими глазами — нам нечего скрывать.</div>
    </div>
  </section>

  <Credentials />
  <Regalia />

  {/* FAQ */}
  <section>
    <div class="section-inner">
      <div class="head">
        <div class="lbl ey">Вопросы и ответы</div>
        <h2>Частые <em>вопросы</em></h2>
        <div class="rule"></div>
      </div>
      <div class="faq">
        {faq.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}</summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="closing">
    <div class="section-inner">
      <h2>Попробуйте <em>живое масло</em></h2>
      <p>Отжимаем под заказ. Доставка по всей России.</p>
      <a href="/catalog" class="btn btn-g">Перейти в каталог</a>
    </div>
  </section>
</Base>
