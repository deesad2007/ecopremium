---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuickContacts from '../components/QuickContacts.astro';
import OrderModal from '../components/OrderModal.astro';
import Analytics from '../components/Analytics.astro';

const {
  title = 'EcoPremi — Живые сыродавленные масла | Поставщик Кремля',
  description = 'Сыродавленные органические масла ручного отжима. Поставщик Московского Кремля, органический сертификат ГОСТ 33980-2016. Свежий отжим под заказ, доставка по России.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || 'https://ekopremium.netlify.app').href;
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="ru_RU" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <Analytics />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <QuickContacts />
  <OrderModal />
</body>
</html>
